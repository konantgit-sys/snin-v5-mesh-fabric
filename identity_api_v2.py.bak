#!/usr/bin/env python3
"""
SNIN Identity API v2 — Layer 5 REST endpoint.

GET  /health              — статус
GET  /identity/:name      — агент по имени + репутация
GET  /identity/did/:did   — поиск по DID
GET  /identity/top        — топ репутации
GET  /identity/all        — все агенты
POST /identity/attest     — аттестация
"""

import json
import os
import sys
import time
from http.server import HTTPServer, BaseHTTPRequestHandler
from urllib.parse import urlparse

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from reputation import calculate_reputation, get_all_reputations, get_reputation_for_pubkey
from mesh_identity import (
    load_or_create_identity, pubkey_to_did, get_all_dids,
    sign_attestation, get_attestations
)
from trust_graph import get_trust_metrics, get_agent_trust
from vc_format import create_did_document, attestation_to_vc

PORT = int(sys.argv[1]) if len(sys.argv) > 1 else 9940


class IdentityHandler(BaseHTTPRequestHandler):

    def _respond(self, code: int, data: dict):
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(json.dumps(data, indent=2, default=str).encode())

    def do_GET(self):
        parsed = urlparse(self.path)
        path = parsed.path.rstrip("/")

        if path == "/health":
            dids = get_all_dids()
            reps = get_all_reputations()
            # Подсчёт живых процессов из identities
            self._respond(200, {
                "status": "ok",
                "layer": "L5 — Identity & Reputation",
                "agents_registered": len(dids),
                "agents_scored": len(reps),
                "uptime": time.time() - _start_time,
                "db_path": str(os.path.expanduser("~/data/sites/relay-mesh/identities/")),
            })

        elif path == "/identity/all":
            agents = []
            dids = get_all_dids()
            for d in dids:
                rep = calculate_reputation(d["agent_name"])
                agents.append({
                    "agent_name": d["agent_name"],
                    "did": d["did"],
                    "npub": d["npub"],
                    "pubkey": d["pubkey"],
                    "reputation": rep["score"],
                    "attestations": d["attestations"],
                    "links": d["links"],
                })
            self._respond(200, {"agents": agents, "count": len(agents)})

        elif path == "/identity/top":
            agents = []
            reps = get_all_reputations()
            for name, rep in sorted(reps.items(), key=lambda x: -x[1]["score"]):
                agents.append({
                    "agent_name": name,
                    "score": rep["score"],
                    "reliability": rep["reliability"],
                    "contribution": rep["contribution"],
                    "age_score": rep["age_score"],
                    "attest_score": rep["attest_score"],
                    "payment_score": rep["payment_score"],
                })
            self._respond(200, {"top": agents[:10], "count": len(agents)})

        elif path.startswith("/identity/did/"):
            did = path[len("/identity/did/"):]
            # Ищем среди известных DID
            all_dids = get_all_dids()
            for d in all_dids:
                if d["did"] == did:
                    rep = calculate_reputation(d["agent_name"])
                    attests = get_attestations(did)
                    self._respond(200, {
                        "agent_name": d["agent_name"],
                        "did": did,
                        "npub": d["npub"],
                        "pubkey": d["pubkey"],
                        "reputation": rep["score"],
                        "attestations": attests,
                        "links": d["links"],
                    })
                    return
            self._respond(404, {"error": f"DID not found: {did}", "known_dids": len(all_dids)})

        elif path.startswith("/identity/"):
            name = path[len("/identity/"):]
            all_dids = get_all_dids()
            for d in all_dids:
                if d["agent_name"] == name:
                    rep = calculate_reputation(name)
                    identity = load_or_create_identity(name)
                    did = pubkey_to_did(identity["mesh_pubkey"])
                    attests = get_attestations(did)
                    self._respond(200, {
                        "agent_name": name,
                        "did": did,
                        "npub": d["npub"],
                        "pubkey": d["pubkey"],
                        "reputation": rep,
                        "attestations": attests,
                        "full_identity": {
                            k: v for k, v in identity.items()
                            if k != "mesh_privkey" and k != "packet_privkey" and k != "cipher_privkey"
                        },
                    })
                    return
            self._respond(404, {"error": f"Agent not found: {name}", "known_agents": [d["agent_name"] for d in all_dids]})

        elif path == "/trust-graph":
            metrics = get_trust_metrics()
            self._respond(200, {
                "service": "SNIN Trust Graph",
                "nodes": metrics["nodes"],
                "edges": metrics["edges"],
                "isolated_agents": metrics["isolated_agents"],
                "top_trusted": metrics["trusted_agents"][:10],
                "graph": metrics["graph"],
            })

        elif path.startswith("/trust/"):
            agent = path[len("/trust/"):]
            trust = get_agent_trust(agent)
            self._respond(200, trust)

        elif path.startswith("/did-document/"):
            # did:snin:pubkey...
            did_query = path[len("/did-document/"):]
            all_dids = get_all_dids()
            found = None
            for d in all_dids:
                if d["did"] == did_query or did_query in d["did"] or did_query in d["pubkey"]:
                    found = d
                    break
            if found:
                doc = create_did_document(found["pubkey"], found["agent_name"])
                self._respond(200, doc)
            else:
                # DID document по pubkey напрямую
                if len(did_query) >= 32:
                    doc = create_did_document(did_query, "unknown")
                    self._respond(200, doc)
                else:
                    self._respond(404, {"error": f"DID not found: {did_query}"})

        elif path.startswith("/vc/"):
            # Получить VC для агента
            agent_query = path[len("/vc/"):]
            all_dids = get_all_dids()
            found = None
            for d in all_dids:
                if d["agent_name"] == agent_query or d["did"] == agent_query:
                    found = d
                    break
            if found:
                rep = calculate_reputation(found["agent_name"])
                vc = attestation_to_vc({
                    "issuer_did": "did:snin:network",
                    "target_did": found["did"],
                    "target": found["did"],
                    "role": "agent",
                    "weight": rep["score"],
                    "description": f"SNIN Agent: {found['agent_name']}",
                })
                self._respond(200, {
                    "agent": found["agent_name"],
                    "did": found["did"],
                    "reputation": rep["score"],
                    "verifiable_credential": vc,
                })
            else:
                self._respond(404, {"error": f"Agent not found: {agent_query}"})

        elif self.path == "/":
            self._respond(200, {"status": "ok", "service": "SNIN Identity API (L5)",
                                "paths": ["/health", "/identity/:name", "/identity/did/:did",
                                          "/identity/top", "/identity/all",
                                          "/trust-graph", "/trust/:agent",
                                          "/did-document/:did", "/vc/:agent"]})
        else:
            self._respond(404, {"error": "Not found",
                                 "paths": ["/health", "/identity/:name", "/identity/did/:did",
                                           "/identity/top", "/identity/all",
                                           "/trust-graph", "/trust/:agent",
                                           "/did-document/:did", "/vc/:agent"]})

    def do_POST(self):
        content_length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(content_length) if content_length else b"{}"
        try:
            data = json.loads(body)
        except json.JSONDecodeError:
            self._respond(400, {"error": "Invalid JSON"})
            return

        parsed = urlparse(self.path)
        path = parsed.path.rstrip("/")

        if path == "/identity/attest":
            required = ["agent_name", "target_did"]
            missing = [k for k in required if k not in data]
            if missing:
                self._respond(400, {"error": f"Missing fields: {missing}"})
                return

            try:
                attestation = sign_attestation(
                    agent_name=data["agent_name"],
                    target_did=data["target_did"],
                    role=data.get("role", "agent"),
                )
                self._respond(200, {"status": "attestation_created", "attestation": attestation})
            except Exception as e:
                self._respond(500, {"error": str(e)})
        else:
            self._respond(404, {"error": f"Unknown path: {path}"})

    def do_OPTIONS(self):
        self.send_response(200)
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Methods", "GET, POST, OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type")
        self.end_headers()

    def log_message(self, format, *args):
        if args and any(str(a).startswith("4") for a in args):
            try:
                super().log_message(format, *args)
            except TypeError:
                pass


_start_time = time.time()

if __name__ == "__main__":
    print(f"[IDENTITY API v2] Starting on :{PORT}")
    server = HTTPServer(("0.0.0.0", PORT), IdentityHandler)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\n[IDENTITY API v2] Shutdown")
        server.server_close()
