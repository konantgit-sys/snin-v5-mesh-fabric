# SNIN Mesh Fabric — Environment Configuration
# Copy this to .env and fill in your keys

# Nostr identity (nsec private key for mesh signing)
# Generate with: https://nostrcheck.me/converter/
MESH_NSEC=nsec1...

# Nostr identity (hex private key format)
MESH_PRIVKEY_HEX=...

# Redis (optional — for GraphMemory and KnowledgeGraph)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# External Nostr relays for publishing (comma-separated)
EXTERNAL_RELAYS=wss://nos.lol,wss://relay.damus.io

# Supervisor webhook URL for alerts
SUPERVISOR_WEBHOOK_URL=

# Log level
LOG_LEVEL=INFO
